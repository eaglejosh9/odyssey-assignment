{
  "name": "odyssey-assignment",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10"
  },
  "scripts": {
    "dev:dashboard": "pnpm --filter @odyssey/dashboard dev",
    "dev:backend": "pnpm --filter @odyssey/backend dev",
    "gen:contract": "pnpm --filter @odyssey/backend gen:openapi && pnpm --filter @odyssey/api-client generate",
    "db:migrate": "pnpm --filter @odyssey/backend db:migrate",
    "db:seed": "pnpm --filter @odyssey/backend db:seed",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "@types/node": "^20.16.10"
  }
}
