{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "jsx": "react-jsx",
    "noEmit": true,
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["expo"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["app/**/*", "src/**/*", "app.config.ts", "babel.config.js"]
}
